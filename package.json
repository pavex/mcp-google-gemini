{
  "name": "mcp-google-gemini",
  "version": "2.0.0",
  "description": "MCP server — Gemini API bridge with smart model cache and fallback",
  "type": "module",
  "main": "dist/mcp.js",
  "bin": {
    "mcp-google-gemini": "dist/mcp.js"
  },
  "scripts": {
    "start": "node dist/mcp.js",
    "dev":   "node src/mcp.js",
    "build": "esbuild src/mcp.js --bundle --platform=node --format=esm --outfile=dist/mcp.js --external:*.node --minify --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "test":  "node test/unit.js && node test/integration.js src && node test/integration.js dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
